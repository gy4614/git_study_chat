{ //ts配置文件 告诉ts编译器 如何编译ts文件
  "compilerOptions": {
    "baseUrl": ".", // 所有路径都从“项目根目录”开始解析
    "module": "ESNext", // 使用 ESNext 模块语法
    "target": "ESNext", //编译成最新版本的 JavaScript
    "lib": [
      "DOM", // 包含 DOM 相关的类型定义
      "ESNext" // 最新版本的 JavaScript 库
    ],
    "strict": true, // 开启严格模式
    "esModuleInterop": true, // 允许在 CommonJS 模块中使用 ES 模块语法
    "allowSyntheticDefaultImports": true, // 允许默认导入
    "jsx": "preserve", // 保持 JSX 语法
    "moduleResolution": "node", // 使用 Node.js 模块解析器
    "resolveJsonModule": true, // 允许导入 JSON 模块
    "noUnusedLocals": true, // 报告未使用的局部变量
    "strictNullChecks": true, // 开启严格空检查
    "forceConsistentCasingInFileNames": true, // 强制文件名大小写一致
    "skipLibCheck": true, // 跳过库文件的类型检查  
    "paths": { // 配置路径别名
      "@/*": [
        "./src/*"
      ]
    },
    "types": [ // 类型定义
      "vite/client",
      "node",
      "naive-ui/volar"
    ]
  },
  "exclude": [ // 不检查这些文件
    "node_modules", // 依赖
    "dist", // 打包后的文件
    "service" // 后端或其他目录
  ]
}